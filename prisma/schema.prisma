// Unifyo 2.0 — Prisma schema
// Zdroj pravdy pre databázu. Každá tabuľka sa riadi odtiaľto.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enumy ────────────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum MembershipTier {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum Plan {
  basic
  pro
  enterprise
}

// ── Používateľ ───────────────────────────────────────────────────
model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String?
  role           Role           @default(USER)
  plan           Plan           @default(basic)
  membershipTier MembershipTier @default(BASIC)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  lastActiveAt   DateTime?
  // Monotonically incremented to invalidate all JWTs ("Odhlásiť všade").
  // Every issued token embeds the current value; requireAuth rejects
  // mismatched tokens. Zero means "never rotated".
  tokenVersion   Int            @default(0)
  // Set when user clicks the verification link. Null means unverified;
  // UI shows a banner and some actions (e.g. paid plans) are gated.
  emailVerifiedAt DateTime?
  // Short, unique, user-facing referral slug (base62, 6 chars). Generated
  // lazily on first /api/referral call. Nullable so legacy users don't
  // block the migration — they get a code the moment they hit the page.
  referralCode    String?   @unique
  // Two-factor authentication (TOTP). `twoFactorSecret` holds the base32
  // secret; while `twoFactorEnabledAt` is null the secret is only a
  // pending setup (not enforced at login). `twoFactorBackupCodes` stores
  // SHA-256 hashes of 10 single-use recovery codes.
  twoFactorSecret       String?
  twoFactorEnabledAt    DateTime?
  twoFactorBackupCodes  String[]  @default([])

  aiRequests    AiRequest[]
  dailyUsage    DailyUsage[]
  neuralMemory  NeuralMemory[]
  crmContacts   CrmContact[]
  crmDeals      CrmDeal[]
  calendarTasks CalendarTask[]
  conversations Conversation[]
  userPolicies  UserPolicy[]
  loginEvents   LoginEvent[]
  authTokens    AuthToken[]
  waitlist      WaitlistSignup[]
  notifications Notification[]
  referralsGiven    Referral[] @relation("referrer")
  referralsReceived Referral[] @relation("referred")
  shareLinks        ShareLink[]
}

// ── Referrals ────────────────────────────────────────────────────
// One row = one successful signup through a referral link. The
// `referredUserId` is unique — a new user can only be credited to a
// single referrer. `rewardedAt` is flipped when we later grant the
// 30-day Pro bonus (done elsewhere once billing goes live).
model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String    @unique
  referred       User      @relation("referred", fields: [referredUserId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  rewardedAt     DateTime?

  @@index([referrerId, createdAt])
}

// ── In-app notifications (bell icon center) ──────────────────────
// Table grows organically from events (signup welcome, future task-due
// worker, broadcasts). No cron cleanup for now — rows are cheap.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "task_due" | "system" | "broadcast" | "welcome"
  title     String
  body      String?
  href      String?
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, createdAt])
  @@index([userId, read])
}

// ── Auth tokens (password reset + email verification) ────────────
// Unified table — purpose field distinguishes. We store SHA-256 hash of
// the token, never the raw value, so a DB leak doesn't hand out working
// reset links. Raw token only ever lives in the email body.
model AuthToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  purpose   String    // "password_reset" | "email_verify"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

// ── Login events (user-visible audit of auth activity) ───────────
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ── AI requesty (audit / usage) ──────────────────────────────────
model AiRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    String
  tokens    Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ── Denný usage counter (tier limit) ─────────────────────────────
model DailyUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

// ── Neural memory (hlavný pamäťový substrát AI) ──────────────────
model NeuralMemory {
  id                String    @id @default(cuid())
  userId            String?
  sessionId         String?
  module            String    @default("dashboard")
  role              String
  content           String
  summary           String?
  embedding         Json?
  importance        Float     @default(0.5)
  isEdited          Boolean   @default(false)
  context           String    @default("work")
  anonymizedContent String?
  confidenceScore   Float     @default(0.5)
  emotionalTone     String    @default("neutral")
  isSimulated       Boolean   @default(false)
  relevanceTTL      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, module])
  @@index([createdAt])
  @@index([userId, context])
  @@index([userId, emotionalTone])
  @@index([relevanceTTL])
}

// ── CRM ──────────────────────────────────────────────────────────
model CrmContact {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  email     String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  notes     CrmNote[]
  deals     CrmDeal[]

  @@index([userId, updatedAt])
}

// ── CRM deal pipeline ───────────────────────────────────────────
// A deal is an opportunity attached to (optionally) a contact. `stage`
// moves left→right through the pipeline; `position` is the in-column
// sort order (smaller = higher in the column). `expectedValue` is in
// EUR cents to avoid float rounding. `lastActivityAt` is bumped on any
// note/stage change — the AI next-step suggestion uses it to detect
// stale deals that need a follow-up.
model CrmDeal {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         CrmContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  title           String
  stage           DealStage @default(LEAD)
  position        Int       @default(0)
  expectedValue   Int?      // EUR cents; null = unknown
  expectedCloseAt DateTime?
  note            String?   // free-form context, rendered in card
  closedAt        DateTime? // set when stage moves to WON or LOST
  lastActivityAt  DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, stage, position])
  @@index([contactId])
}

enum DealStage {
  LEAD       // new, not yet contacted
  QUALIFIED  // confirmed interest
  PROPOSAL   // offer sent
  WON        // closed — success
  LOST       // closed — lost
}

model CrmNote {
  id        String     @id @default(cuid())
  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime   @default(now())

  @@index([contactId, createdAt])
}

// ── Kalendár ─────────────────────────────────────────────────────
model CalendarTask {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  date        String // YYYY-MM-DD
  time        String? // HH:MM
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
}

// ── Konverzácie (AI chat histórie) ───────────────────────────────
model Conversation {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String            @default("Nová konverzácia")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  messages  ConversationMsg[]

  @@index([userId, updatedAt])
}

model ConversationMsg {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  tokens         Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ── Membership plans (upraviteľné adminom v reálnom čase) ────────
model MembershipPlan {
  tier          MembershipTier @id
  label         String
  dailyRequests Int?
  memorySlots   Int
  contextWindow Int
  userPolicies  Int
  price         Float
  description   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ── Globálne neural policies (admin) ─────────────────────────────
model NeuralPolicy {
  id        String   @id @default(cuid())
  name      String
  rule      String
  severity  String   @default("medium") // low | medium | high | critical
  context   String   @default("all") // all | personal | work
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([context])
}

// ── Používateľské policies (osobné pravidlá pre AI) ──────────────
model UserPolicy {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  rule      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── Audit log (admin akcie) ──────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  targetId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([adminEmail])
}

// ── Error log (interný Sentry-lite) ─────────────────────────────
// Každý row = jedna occurrence. Podobné chyby zdieľajú `fingerprint`
// (16-hex hash z name + first stack frame), takže admin môže grupovať.
// `notifiedAt` je nastavený len na prvom výskyte v 24h okne — tak
// zabraňujeme flood emailom keď sa niečo rozbije pre 500 userov.
model ErrorLog {
  id          String   @id @default(cuid())
  fingerprint String   // stable hash pre grupovanie similar errors
  source      String   // "client" | "server" | "edge"
  level       String   @default("error") // "error" | "warn"
  name        String?  // napr. "TypeError", "PrismaClientKnownRequestError"
  message     String   @db.Text
  stack       String?  @db.Text
  url         String?  // kde chyba nastala (path alebo full URL)
  userAgent   String?
  userId      String?  // ak bol prihlásený
  userEmail   String?  // snapshot pre prípad že user neskôr zanikne
  digest      String?  // Next.js error digest (pre cross-ref s error.tsx)
  meta        Json?    // ľubovoľný ďalší kontext (request headers, params…)
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  notifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([fingerprint, createdAt])
  @@index([resolved, createdAt])
  @@index([createdAt])
}

// ── Shared rate-limit hits ──────────────────────────────────────
// Persistent store pre rate-limiting. Predtým sme mali Map v RAM —
// PM2 reštart = reset limitov, pri multi-instance deploye to navyše
// vôbec nefunguje (každý proces má vlastné okno).
//
// Row = jeden hit. Cleanup lazy: 1% chance pri každom hite zmažeme
// všetky riadky staršie ako 1h. Takže tabuľka ostáva malá, žiadny cron.
model RateLimitHit {
  id        String   @id @default(cuid())
  key       String   // format: "prefix:ip"
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// ── Analytics events (self-hosted, GDPR-friendly) ────────────────
// Minimal event collector. IP je skrátený o posledný oktet pred uložením.
// No PII by design — props je voľný Json pre konkrétnu udalosť, ale klient
// helper by tam nemal posielať e-maily či mená.
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  props     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([userId, createdAt])
}

// Waitlist — užívateľ (alebo anon email) sa prihlási na notifikáciu
// keď bude konkrétny "coming soon" modul hotový. Feature = slug modulu
// (email | calls | analytics | automation | ...). userId je optional,
// email povinný. Unikátnosť per-feature aby to nespamovalo tú istú
// osobu opakovaným kliknutím.
model WaitlistSignup {
  id        String   @id @default(cuid())
  feature   String
  email     String
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([feature, email])
  @@index([feature, createdAt])
  @@index([userId])
}

// ── Share links ─────────────────────────────────────────────────
// Public read-only links for sharing a CalendarTask or CrmContact
// without forcing the recipient to sign up. Token is URL-safe random
// (~22 chars base64url from 16 random bytes). Optional expiry and
// manual revocation supported. viewCount is an incrementing counter.
model ShareLink {
  id           String    @id @default(cuid())
  token        String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceType String    // "task" | "contact"
  resourceId   String
  createdAt    DateTime  @default(now())
  expiresAt    DateTime? // null = no expiry
  revokedAt    DateTime?
  viewCount    Int       @default(0)

  @@index([userId, createdAt])
  @@index([token])
}
