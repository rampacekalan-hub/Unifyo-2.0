// Unifyo 2.0 — Prisma schema
// Zdroj pravdy pre databázu. Každá tabuľka sa riadi odtiaľto.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enumy ────────────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum MembershipTier {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum Plan {
  basic
  pro
  enterprise
}

// ── Používateľ ───────────────────────────────────────────────────
model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String?
  role           Role           @default(USER)
  plan           Plan           @default(basic)
  membershipTier MembershipTier @default(BASIC)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  lastActiveAt   DateTime?

  aiRequests    AiRequest[]
  dailyUsage    DailyUsage[]
  neuralMemory  NeuralMemory[]
  crmContacts   CrmContact[]
  calendarTasks CalendarTask[]
  conversations Conversation[]
  userPolicies  UserPolicy[]
}

// ── AI requesty (audit / usage) ──────────────────────────────────
model AiRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    String
  tokens    Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ── Denný usage counter (tier limit) ─────────────────────────────
model DailyUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

// ── Neural memory (hlavný pamäťový substrát AI) ──────────────────
model NeuralMemory {
  id                String    @id @default(cuid())
  userId            String?
  sessionId         String?
  module            String    @default("dashboard")
  role              String
  content           String
  summary           String?
  embedding         Json?
  importance        Float     @default(0.5)
  isEdited          Boolean   @default(false)
  context           String    @default("work")
  anonymizedContent String?
  confidenceScore   Float     @default(0.5)
  emotionalTone     String    @default("neutral")
  isSimulated       Boolean   @default(false)
  relevanceTTL      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, module])
  @@index([createdAt])
  @@index([userId, context])
  @@index([userId, emotionalTone])
  @@index([relevanceTTL])
}

// ── CRM ──────────────────────────────────────────────────────────
model CrmContact {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  email     String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  notes     CrmNote[]

  @@index([userId, updatedAt])
}

model CrmNote {
  id        String     @id @default(cuid())
  contactId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime   @default(now())

  @@index([contactId, createdAt])
}

// ── Kalendár ─────────────────────────────────────────────────────
model CalendarTask {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  date        String // YYYY-MM-DD
  time        String? // HH:MM
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
}

// ── Konverzácie (AI chat histórie) ───────────────────────────────
model Conversation {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String            @default("Nová konverzácia")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  messages  ConversationMsg[]

  @@index([userId, updatedAt])
}

model ConversationMsg {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  tokens         Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ── Membership plans (upraviteľné adminom v reálnom čase) ────────
model MembershipPlan {
  tier          MembershipTier @id
  label         String
  dailyRequests Int?
  memorySlots   Int
  contextWindow Int
  userPolicies  Int
  price         Float
  description   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ── Globálne neural policies (admin) ─────────────────────────────
model NeuralPolicy {
  id        String   @id @default(cuid())
  name      String
  rule      String
  severity  String   @default("medium") // low | medium | high | critical
  context   String   @default("all") // all | personal | work
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([context])
}

// ── Používateľské policies (osobné pravidlá pre AI) ──────────────
model UserPolicy {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  rule      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── Audit log (admin akcie) ──────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  targetId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([adminEmail])
}
