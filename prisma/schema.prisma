// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum Plan {
  basic
  pro
  enterprise
}

enum MembershipTier {
  BASIC
  PREMIUM
  ENTERPRISE
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String?
  role           Role           @default(USER)
  plan           Plan           @default(basic)
  membershipTier MembershipTier @default(BASIC)
  lastActiveAt   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  aiRequests    AiRequest[]
  dailyUsages   DailyUsage[]
  userPolicies  UserPolicy[]
  conversations Conversation[]
  crmContacts   CrmContact[]
  calendarTasks CalendarTask[]
}

// ── Chat Conversations ─────────────────────────────────────────
model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Nová konverzácia")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMsg[]

  @@index([userId, createdAt])
}

model ConversationMsg {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String
  tokens         Int      @default(0)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ── CRM ────────────────────────────────────────────────────────
model CrmContact {
  id        String    @id @default(cuid())
  userId    String
  name      String
  company   String?
  email     String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes CrmNote[]

  @@index([userId])
}

model CrmNote {
  id        String   @id @default(cuid())
  contactId String
  content   String
  createdAt DateTime @default(now())

  contact CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

// ── Calendar ───────────────────────────────────────────────────
model CalendarTask {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  date        String   // YYYY-MM-DD
  time        String?  // HH:MM
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model AiRequest {
  id        String   @id @default(cuid())
  userId    String
  module    String
  tokens    Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Daily usage counter per user per day ──────────────────────
model DailyUsage {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ── Membership Plans — editable tier limits stored in DB ──────
model MembershipPlan {
  id             String   @id @default(cuid())
  tier           String   @unique // "BASIC" | "PREMIUM" | "ENTERPRISE"
  label          String
  dailyRequests  Int?     // null = unlimited
  memorySlots    Int
  contextWindow  Int
  userPolicies   Int      @default(2)   // max personal policies
  price          Float    @default(0)   // monthly EUR price (display only)
  description    String   @default("")
  updatedAt      DateTime @updatedAt

  @@index([tier])
}

// ── User Personal Policies — per-user AI instructions ────────
model UserPolicy {
  id        String   @id @default(cuid())
  userId    String
  name      String   // short label, e.g. "Vždy mi tykaj"
  rule      String   // injected after global policies
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

// ── Neural Policy Engine — top-priority AI instructions ────────
model NeuralPolicy {
  id          String   @id @default(cuid())
  name        String   // short label, e.g. "No financial advice"
  rule        String   // full instruction text injected into system prompt
  severity    String   @default("medium") // "low" | "medium" | "high" | "critical"
  context     String   @default("all")   // "all" | "personal" | "work"
  isActive    Boolean  @default(true)
  createdBy   String?  // admin email
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, severity])
  @@index([context])
}

// ── Audit Trail — immutable log of NeuralMemory changes ────────
model AuditLog {
  id          String   @id @default(cuid())
  adminEmail  String
  action      String   // "EDIT" | "DELETE" | "ARCHIVE" | "BULK_DELETE" | "BULK_ARCHIVE" | "RECATEGORIZE" | "PURGE"
  targetId    String?  // NeuralMemory.id (null for bulk)
  targetIds   Json?    // array of ids for bulk actions
  before      Json?    // snapshot of changed fields before
  after       Json?    // snapshot of changed fields after
  metadata    Json?    // extra context (e.g. reason, filter used)
  createdAt   DateTime @default(now())

  @@index([adminEmail])
  @@index([createdAt])
  @@index([action])
}

// ── Neural Memory — on-premise vector-ready knowledge store ───
model NeuralMemory {
  id                 String   @id @default(cuid())
  userId             String?  // null = global system memory
  sessionId          String?  // groups memories from one conversation
  module             String   @default("dashboard")
  role               String   // "user" | "assistant" | "system"
  content            String   // original text (stored locally only)
  anonymizedContent  String?  // GDPR-safe version sent to admin view
  summary            String?  // admin-editable distilled knowledge
  context            String   @default("work") // "personal" | "work" — auto-tagged by AI
  confidenceScore    Float    @default(0.5)    // 0-1 AI self-evaluation
  emotionalTone      String   @default("neutral") // "positive"|"negative"|"neutral"|"anxious"|"excited"
  relevanceTTL       DateTime?                // null = permanent; set = auto-stale after this date
  embedding          Json?    // placeholder for pgvector
  importance         Float    @default(0.5)    // 0-1 admin-adjustable weight
  isEdited           Boolean  @default(false)  // true if admin manually corrected
  isSimulated        Boolean  @default(false)  // true = Brain Sandbox test entry
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId, module])
  @@index([userId, context])
  @@index([userId, emotionalTone])
  @@index([createdAt])
  @@index([relevanceTTL])
}
